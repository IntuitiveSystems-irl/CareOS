# BigQuery dataset CDR reference (All of Us Researcher Workbench)
WORKSPACE_CDR=your-project.your-dataset

# API security
MED_ACCESS_API_KEY=change-me-to-a-strong-random-key
MED_ACCESS_JWT_SECRET=change-me-jwt-secret-key

# Optional: GCP credentials path (if not using default ADC)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Logging
LOG_LEVEL=INFO
