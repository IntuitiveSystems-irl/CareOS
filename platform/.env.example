# CareOS platform — environment template.
# Copy to `.env` in this directory and fill in real values.
# `.env` is git-ignored (see root .gitignore); NEVER commit real secrets.
# Docker Compose auto-loads `.env` from this directory for ${VAR} interpolation.

# ── Database ──
# Use a long, randomly generated password (e.g. `openssl rand -base64 24`).
POSTGRES_PASSWORD=change-me-strong-password

# ── Researcher dashboard / data export gate ──
# Long random string. Empty = researcher access disabled (fail-closed).
RESEARCH_ADMIN_PASSCODE=

# ── Transactional email (Resend) ──
RESEND_API_KEY=

# ── Integration relay PHI envelope-encryption key ──
# Generate: python -c 'from app.integration.crypto import generate_kek; print(generate_kek())'
LAUNCHFLOW_RELAY_KEK=

# ── AI layer ──
OPENAI_API_KEY=

# ── HL7 MLLP allowed peer IPs (comma-separated; empty = any in docker net) ──
RELAY_HL7_MLLP_PEERS=

# ── Encrypted DB backups (used by ops/backup-db.sh) ──
# Long passphrase for symmetric backup encryption. Store in a secret manager.
BACKUP_PASSPHRASE=

# ── Cloudflare Tunnel (local + tunnel deployment only) ──
# Token from Cloudflare Zero Trust → Networks → Tunnels → your tunnel → Configure.
# Used when running: cloudflared tunnel run --token $CLOUDFLARE_TUNNEL_TOKEN
CLOUDFLARE_TUNNEL_TOKEN=
